{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "xdownload",
  "main": "worker/worker.js",
  "compatibility_date": "2026-06-13",
  "observability": {
    "enabled": false
  },
  "assets": {
    "directory": "public",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
